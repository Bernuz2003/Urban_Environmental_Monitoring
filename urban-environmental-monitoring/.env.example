POSTGRES_DB=urban_monitoring
POSTGRES_USER=urban
POSTGRES_PASSWORD=urban_demo_password

INFLUX_ORG=polito
INFLUX_TOKEN=PASTE_THE_OPERATOR_TOKEN_CREATED_IN_THE_UI

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Timestamp precision used by the historical Line Protocol bundles.
INFLUX_LINE_PROTOCOL_PRECISION=us

# Continuous producer cadence. At 60 seconds, every active sensor emits once per minute.
LIVE_INTERVAL_SECONDS=60
