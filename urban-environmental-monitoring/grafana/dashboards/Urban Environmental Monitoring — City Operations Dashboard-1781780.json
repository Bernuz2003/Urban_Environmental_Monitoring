          "query": "import \"array\"\n\nalerts =\n    from(bucket: \"urban_alerts\")\n        |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n        |> filter(fn: (r) =>\n            r._measurement == \"urban_alerts\" and\n            r._field == \"severity_level\"\n        )\n        |> group(columns: [])\n        |> max(column: \"_value\")\n        |> keep(columns: [\"_value\"])\n\nfallback =\n    array.from(rows: [{_value: 0}])\n\nunion(tables: [alerts, fallback])\n    |> group(columns: [])\n    |> max(column: \"_value\")\n    |> map(fn: (r) => ({\n        _time: now(),\n        _value: int(v: r._value)\n    }))\n    |> yield(name: \"city_status\")",
